NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Pooled (e.g. :6543 ?pgbouncer=true) — used by the Next.js app (src/lib/prisma.ts)
DATABASE_URL=
# Direct db.*:5432 — Prisma CLI prefers this when set (migrate, db push)
DIRECT_URL=
# P1001 on migrate? Try PRISMA_CLI_USE_DATABASE_URL=1 first, or set Session pooler URI:
# https://supabase.com/dashboard/project/_/settings/database
MIGRATE_DATABASE_URL=
PRISMA_CLI_USE_DATABASE_URL=
UPLISTING_API_KEY=
# Webhook key from Uplisting Connect > Webhook (used to verify POST /api/webhooks/uplisting)
UPLISTING_WEBHOOK_SECRET=
# Optional override (default: https://connect.uplisting.io)
UPLISTING_BASE_URL=
